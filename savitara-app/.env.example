# ============================================================
# Savitara Mobile App — Expo Environment Variables
# ============================================================
# 1. Copy:  cp .env.example .env
# 2. For physical device testing, use your machine's LAN IP
#    instead of localhost.  Find it with: ipconfig | findstr IPv4
# ============================================================

# ── API ───────────────────────────────────────────────────────
# Dev (simulator):
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Dev (physical Android/iOS on same LAN):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.XXX:8000/api/v1
# Production:
# EXPO_PUBLIC_API_BASE_URL=https://api.savitara.com/api/v1

# ── Google OAuth ──────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Add redirect URI: com.savitara.app:/oauth2redirect
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Razorpay ──────────────────────────────────────────────────
# Use rzp_test_ key in dev, rzp_live_ key in production
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_here

# ── Firebase (Push Notifications via FCM) ─────────────────────
# Get these from Firebase Console → Project Settings → Your apps
# android: google-services.json must also be placed in android/app/
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:app:abcdef

# ── Sentry (optional but recommended for production) ─────────
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
